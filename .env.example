# Domain sumber yang akan di-mirror
SOURCE_HOST=www.crossingbroad.com

# Domain mirror kamu (WAJIB diisi untuk production)
MIRROR_DOMAIN=crossingbroad.xyz

# Protocol mirror (https atau http)
MIRROR_PROTO=https

# Port server (Railway/Render auto set via PORT env)
PORT=3000

# Cache TTL dalam detik (default 5 menit)
CACHE_TTL=300
